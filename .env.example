# Required
APIFY_API_TOKEN=your_apify_token_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Protects the /run endpoint from unauthorized triggers
CRON_SECRET=change_me_to_a_random_string

# Database (Railway provides this automatically when you add Postgres)
DATABASE_URL=sqlite:///./rental_scout.db

# Your name for draft messages
RENTER_NAME=Ameer
RENTER_BIO=Software engineer, stable income, clean, quiet tenant

# Search criteria
MAX_PRICE=2800
BEDROOMS=1
TARGET_MOVE_IN=2026-09-01
ALT_MOVE_IN=2026-08-01
SEARCH_AREA=Cambridge, MA
TARGET_NEIGHBORHOODS=Cambridge,Somerville,Allston,Brighton,Inman Square,Central Square,Harvard Square,Porter Square,Davis Square,Kendall Square,East Cambridge,East Somerville,Union Square

# Apify actor IDs — verify these in the Apify Store, actors get updated/renamed
CRAIGSLIST_ACTOR=voyager/craigslist-scraper
ZILLOW_ACTOR=maxcopell/zillow-scraper
APARTMENTS_ACTOR=epctex/apartments-scraper
REALTOR_ACTOR=maxcopell/realtor-scraper
REDFIN_ACTOR=epctex/redfin-scraper
FACEBOOK_ACTOR=apify/facebook-marketplace-scraper
RENT_ACTOR=epctex/rent-scraper

# Optional: disable specific scrapers (set to false)
ENABLE_CRAIGSLIST=true
ENABLE_ZILLOW=true
ENABLE_APARTMENTS=true
ENABLE_REALTOR=true
ENABLE_REDFIN=true
ENABLE_FACEBOOK=true
ENABLE_RENT=true
